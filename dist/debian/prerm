#!/bin/sh
set -e

case "$1" in
    remove|upgrade)
        # Stop and disable service before removal
        if systemctl is-active --quiet runifi 2>/dev/null; then
            systemctl stop runifi || true
        fi
        if systemctl is-enabled --quiet runifi 2>/dev/null; then
            systemctl disable runifi || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
